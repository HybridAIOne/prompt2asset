# https://aistudio.google.com/apikey — never commit real keys.
# Lokal: hier eintragen. Auf der GitHub-Pages-Demo: leer lassen und Key im Browser-Banner (nur Sitzung) speichern.
VITE_GEMINI_API_KEY=

# Default: Gemini 3 Flash (wie Server-Setup; siehe https://ai.google.dev/gemini-api/docs/models )
# Alternatives: gemini-3.1-pro-preview, gemini-3.1-flash-lite-preview
VITE_GEMINI_MODEL=gemini-3-flash-preview
